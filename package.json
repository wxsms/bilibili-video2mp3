{
  "name": "bv2mp3",
  "version": "3.1.0",
  "description": "A tool to download all videos and convert to mp3 inside a video set of bilibili (also works for single video, of course).",
  "bin": "src/index.js",
  "type": "module",
  "author": "wxsms@foxmail.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wxsms/bilibili-video2mp3.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wxsms/bilibili-video2mp3/issues"
  },
  "homepage": "https://github.com/wxsms/bilibili-video2mp3",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "lint": "eslint . --fix",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s -r 0",
    "test": "vitest run --exclude tests/e2e.test.js",
    "test:e2e": "vitest run tests/e2e.test.js",
    "test:e2e-mock": "vitest run tests/e2e-mock.test.js"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.10",
    "@ffmpeg/ffmpeg": "0.12.15",
    "axios": "1.16.1",
    "commander": "14.0.3",
    "filenamify": "7.0.1",
    "lodash-es": "4.18.1",
    "multi-progress": "4.0.0",
    "progress": "2.0.3"
  },
  "devDependencies": {
    "@eslint/js": "8.57.1",
    "@vitest/coverage-v8": "4.1.7",
    "conventional-changelog-cli": "5.0.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "vitest": "4.1.7"
  }
}
